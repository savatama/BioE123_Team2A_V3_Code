/*
  V3 Centrifuge Sensor Subsystem

  PURPOSE:
  - This is our SENSOR subsystem test for V3.
  - We count rotations using an interrupt (LM393 comparator output -> digital pin 7).
  - We calculate RPM every fixed time window using millis() (no delay()).
  - We preserve V3 sensor improvements including:
      * glitch reject in the ISR
      * pulsesPerRev scaling
      * RPM spike clamp
      * sensor failure detection
  - We let the user set a targetRPM and a spin time using the Serial Monitor.
  - We can START and STOP the run.
  - We check for sensor failure while running.
  - We output a PWM signal on pin 6 as a placeholder motor command.

  HOW TO USE (Serial Monitor):
  1) Type a target RPM number (example: 1500) and press Enter
  2) Type a spin time in seconds (example: 30) and press Enter
  3) Type 's' and press Enter to start
  4) Type 'x' and press Enter to stop at any time
  5) Type 'r' and press Enter to reset and enter new RPM / time
*/

volatile unsigned long rotationCounter = 0;

// V3 ISR glitch reject
volatile unsigned long lastPulseMicros = 0;
const unsigned long minPulseIntervalMicros = 2000;

// V3 pulse scaling
const float pulsesPerRev = 6.0;

// Pin assignments
const int interruptPin = 7;   // LM393 output
const int motorPWMPin  = 6;   // placeholder PWM command output

const bool useInterruptPullup = true;
const int interruptEdgeMode = FALLING;

// User-set variables
int targetRPM = 0;
unsigned long spinTimeMs = 0;

// Run state
bool running = false;
unsigned long startTime = 0;

// RPM calculation variables
const unsigned long rpmWindowMs = 250;
unsigned long lastRPMTime = 0;
float measuredRPM = 0;
float filteredRPM = 0;

// Spike clamp
const float maxDeltaRPMPerWindow = 1200.0;

// Sensor-failure detection
const int minPWMForSensorCheck = 80;
const int sensorFailConfirmWindows = 3;
int zeroCountWindows = 0;
bool sensorFaultLatched = false;

// Placeholder motor command
int pwmCmd = 0;

// ISR
void rotationISR() {
  unsigned long now = micros();
  unsigned long dt = now - lastPulseMicros;

  if (dt >= minPulseIntervalMicros) {
    lastPulseMicros = now;
    rotationCounter++;
  }
}

void resetPulseState() {
  noInterrupts();
  rotationCounter = 0;
  lastPulseMicros = micros();
  interrupts();
}

void checkSensorFailure(unsigned long countsThisWindow) {
  if (!running) {
    zeroCountWindows = 0;
    return;
  }

  if (pwmCmd >= minPWMForSensorCheck && countsThisWindow == 0) {
    zeroCountWindows++;
  } else {
    zeroCountWindows = 0;
  }

  if (zeroCountWindows >= sensorFailConfirmWindows) {
    sensorFaultLatched = true;
    running = false;
    analogWrite(motorPWMPin, 0);
    Serial.println("SENSOR_FAULT");
  }
}

void setup() {
  Serial.begin(9600);

  if (useInterruptPullup) {
    pinMode(interruptPin, INPUT_PULLUP);
  } else {
    pinMode(interruptPin, INPUT);
  }

  pinMode(motorPWMPin, OUTPUT);
  analogWrite(motorPWMPin, 0);

  attachInterrupt(digitalPinToInterrupt(interruptPin), rotationISR, interruptEdgeMode);

  Serial.println("V3 Sensor Code Ready");
  Serial.println("Enter target RPM (ex: 1500), then press Enter:");
}

void loop() {
  // 1) SERIAL INPUT HANDLING
  if (Serial.available() > 0) {
    char c = Serial.peek();

    if (c == 's' || c == 'S') {
      Serial.read();

      if (targetRPM <= 0 || spinTimeMs == 0) {
        Serial.println("Set RPM and TIME first.");
      } else {
        running = true;
        sensorFaultLatched = false;
        startTime = millis();
        lastRPMTime = millis();
        measuredRPM = 0;
        filteredRPM = 0;
        zeroCountWindows = 0;

        noInterrupts();
        rotationCounter = 0;
        interrupts();

        Serial.println("STARTING");
      }
    }

    else if (c == 'x' || c == 'X') {
      Serial.read();
      running = false;
      analogWrite(motorPWMPin, 0);
      Serial.println("STOPPED.");
    }

    else if (c == 'r' || c == 'R') {
      Serial.read();
      running = false;
      analogWrite(motorPWMPin, 0);

      targetRPM = 0;
      spinTimeMs = 0;
      measuredRPM = 0;
      filteredRPM = 0;
      zeroCountWindows = 0;
      sensorFaultLatched = false;

      Serial.println("Reset done. Enter target RPM again:");
    }

    else {
      int val = Serial.parseInt();

      if (val > 0) {
        if (targetRPM == 0) {
          targetRPM = val;
          Serial.print("targetRPM set to ");
          Serial.println(targetRPM);
          Serial.println("Enter spin time (seconds), then press Enter:");
        } else if (spinTimeMs == 0) {
          spinTimeMs = (unsigned long)val * 1000UL;
          Serial.print("spinTime set to ");
          Serial.print(val);
          Serial.println(" seconds");
          Serial.println("Type 's' to start, 'x' to stop, 'r' to reset.");
        } else {
          targetRPM = val;
          Serial.print("updated targetRPM to ");
          Serial.println(targetRPM);
        }
      }
    }
  }

  // 2) RUNNING LOGIC
  if (running) {
    // Placeholder motor command
    pwmCmd = map(constrain(targetRPM, 0, 1950), 0, 1950, 0, 255);
    analogWrite(motorPWMPin, pwmCmd);

    unsigned long now = millis();
    if (now - lastRPMTime >= rpmWindowMs) {
      unsigned long dt = now - lastRPMTime;
      lastRPMTime = now;

      noInterrupts();
      unsigned long counts = rotationCounter;
      rotationCounter = 0;
      interrupts();

      float dtSec = dt / 1000.0;
      float rawRPM = 0.0;

      if (dtSec > 0) {
        rawRPM = ((counts / pulsesPerRev) / dtSec) * 60.0;
      }

      if (filteredRPM == 0) {
        filteredRPM = rawRPM;
      }

      float delta = rawRPM - filteredRPM;
      if (delta > maxDeltaRPMPerWindow) rawRPM = filteredRPM + maxDeltaRPMPerWindow;
      if (delta < -maxDeltaRPMPerWindow) rawRPM = filteredRPM - maxDeltaRPMPerWindow;

      filteredRPM = rawRPM;
      measuredRPM = filteredRPM;

      Serial.print("RPM: ");
      Serial.print(measuredRPM);
      Serial.print("  target: ");
      Serial.print(targetRPM);
      Serial.print("  PWM: ");
      Serial.println(pwmCmd);

      checkSensorFailure(counts);
    }

    if (millis() - startTime >= spinTimeMs) {
      running = false;
      analogWrite(motorPWMPin, 0);
      Serial.println("Centrifugation Done");
    }
  }
}
